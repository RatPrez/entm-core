{
    "name": "entm-core",
    "version": "1.0.0",
    "description": "Entity Component System for FiveM",
    "scripts": {
        "build":     "npm run clean && node build/bundle.js",
        "watch":     "cross-env IS_WATCH_MODE=1 node build/bundle.js",
        "typecheck": "tsc --noEmit -p src/client/tsconfig.json && tsc --noEmit -p src/server/tsconfig.json",
        "clean":     "rimraf dist"
    },
    "license": "ISC",
    "devDependencies": {
        "@ratprez/entm": "^0.5.0",
        "@citizenfx/client": "^2.0.29753-1",
        "@citizenfx/server": "^2.0.29753-1",
        "@types/node": "^25.9.2",
        "cross-env": "^10.1.0",
        "esbuild": "^0.28.0",
        "rimraf": "^6.1.3",
        "typescript": "^6.0.3"
    }
}
